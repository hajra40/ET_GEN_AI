// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AssumptionsPanel > matches the trust-surface snapshot 1`] = `"<div class="rounded-2xl border border-white/70 bg-white/90 p-5 shadow-card backdrop-blur-sm"><div class="mb-4 flex justify-between flex-col items-start gap-3"><div class="space-y-1"><h3 class="text-lg font-semibold tracking-tight text-foreground">Assumptions and trust</h3><p class="text-sm text-muted-foreground">What the planner assumed, how strong the data is, and what could improve accuracy.</p></div><div class="flex flex-wrap gap-2"><span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium bg-amber-100 text-amber-900">ESTIMATED (78/100)</span></div></div><div class="space-y-4 grid gap-4 md:grid-cols-[1.2fr,0.8fr]"><div class="space-y-3"><div class="rounded-2xl border border-border/70 bg-secondary/30 p-4"><div class="flex items-center justify-between gap-3"><p class="font-semibold">Planning inflation</p><p class="text-sm text-muted-foreground">6%</p></div><p class="mt-2 text-sm leading-6 text-muted-foreground">Used for long-term expense inflation.</p></div></div><div class="space-y-3"><div class="rounded-2xl border border-border/70 bg-secondary/30 p-4"><p class="font-semibold">Confidence note</p><p class="mt-2 text-sm leading-6 text-muted-foreground">Forward-looking assumptions are still required.</p></div><div class="rounded-2xl border border-border/70 bg-secondary/30 p-4"><p class="font-semibold">Missing inputs that could improve accuracy</p><div class="mt-2 space-y-2"><p class="text-sm leading-6 text-muted-foreground">Exact rent would improve tax precision.</p></div></div></div></div></div>"`;
